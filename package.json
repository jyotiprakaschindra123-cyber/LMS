{
  "name": "utkal-reserve-hms",
  "version": "1.0.0",
  "description": "Utkal Reserve hotel management system built with the MERN stack.",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node --watch server/index.js",
    "client": "vite --host 0.0.0.0 --config client/vite.config.js --port 5174",
    "start": "node server/index.js",
    "seed": "node server/seed.js",
    "build": "vite build --config client/vite.config.js",
    "preview": "vite preview --host 0.0.0.0 --config client/vite.config.js"
  },
  "keywords": [
    "hotel",
    "management",
    "mern",
    "booking"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "bcryptjs": "^3.0.3",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.8.0",
    "mongoose": "^9.5.0",
    "morgan": "^1.10.1",
    "nodemailer": "^8.0.5",
    "razorpay": "^2.9.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1",
    "vite": "^8.0.9"
  }
}
